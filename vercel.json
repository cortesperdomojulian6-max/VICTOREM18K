{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/components/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/components/(.*)",
      "dest": "frontend/components/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/public/$1"
    }
  ]
}
