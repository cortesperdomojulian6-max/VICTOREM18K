# ============================================
# PLANTILLA DE VARIABLES DE ENTORNO - VICTOREM
# ============================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env NO debe subirse a Git.
# ============================================

# Conexión a PostgreSQL (obtener desde el panel de Supabase -> Connect -> Session pooler)
DATABASE_URL=postgresql://postgres.<proyecto>:<password>@<host>.pooler.supabase.com:5432/postgres

# Clave secreta para JWT (mínimo 32 caracteres, generada aleatoriamente)
JWT_SECRET=cambia_esta_clave_por_una_aleatoria_y_larga

# Puerto del servidor
PORT=3000
HOST=0.0.0.0

# Entorno
NODE_ENV=development
