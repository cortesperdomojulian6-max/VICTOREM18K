# =============================================================================
# Victorem — Variables de Entorno (ejemplo)
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# --- Base de datos (PostgreSQL / Supabase) ---
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT ---
JWT_SECRET=your_jwt_secret_here_change_this

# --- Wompi (pasarela de pagos) ---
WOMPI_PUBLIC_KEY=pub_prod_YOUR_PUBLIC_KEY
WOMPI_API_KEY=prv_prod_YOUR_PRIVATE_KEY
WOMPI_EVENTS_SECRET=prod_events_YOUR_EVENTS_SECRET

# --- Aplicación ---
NEXT_PUBLIC_APP_URL=https://victorem.co
