# ============================================
# PLANTILLA DE VARIABLES DE ENTORNO - VICTOREM
# ============================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env NO debe subirse a Git.
# ============================================

# ========== BASE DE DATOS ==========
# Conexión a PostgreSQL (obtener desde panel Supabase -> Connect -> Session pooler)
DATABASE_URL=postgresql://postgres.<proyecto>:<password>@<host>.pooler.supabase.com:5432/postgres

# ========== SEGURIDAD JWT ==========
# Clave secreta para JWT (mínimo 32 caracteres, generada aleatoriamente)
JWT_SECRET=cambia_esta_clave_por_una_aleatoria_y_larga

# ========== CONFIGURACIÓN DEL SERVIDOR ==========
# Puerto del servidor
PORT=3000
HOST=0.0.0.0

# Entorno (development, production)
NODE_ENV=development

# CORS: Origen permitido para solicitudes
CORS_ORIGIN=http://localhost:3000

# ========== INTEGRACION WOMPI (Pasarela de Pagos) ==========
# API Key de Wompi (obtenida del dashboard)
WOMPI_API_KEY=tu_wompi_api_key_aqui
WOMPI_PUBLIC_KEY=tu_wompi_public_key_aqui
# Entorno Wompi: sandbox o production
WOMPI_ENVIRONMENT=sandbox

# ========== NOTIFICACIONES (OPCIONAL) ==========
# Configuración de email para notificaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_aplicacion
SENDER_EMAIL=noreply@victorem.com
